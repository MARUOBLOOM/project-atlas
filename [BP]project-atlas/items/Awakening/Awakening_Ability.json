{
    "format_version": "1.20.60",
    "minecraft:item": {
        "description": {
            "identifier": "pvp:awakening_ability",
            /*クリエイティブのアイテム欄に表示する設定*/
            "menu_category": {
                "category": "items"
            }
        },
        "components": {
            /*1スタックが何個かの設定(デフォルトは64)*/
            "minecraft:max_stack_size": {
                "value": 1
            },
            "minecraft:use_animation": "eat",
            "minecraft:food": {
                "can_always_eat": true,
                "nutrition": 1,
                "saturation_modifier": 1
            },
            "minecraft:use_modifiers": {
                "movement_modifier": 0.85,
                "use_duration": 1
            },
            /*アクションバーに表示されるアイテム名の設定(langファイルでも設定可)*/
            "minecraft:display_name": {
                "value": "§b覚醒の果実"
            },
            /*アイテムのアイコン設定(RPのitem_texture.jsonでの設定要)*/
            "minecraft:icon": {
                "textures": {
                    "default": "Awakening_Ability"
                }
            }
        }
    }
}