{
    "format_version": "1.20.60",
    "minecraft:item": {
        "description": {
            "identifier": "pvp:timeeater_passive_health",
            /*クリエイティブのアイテム欄に表示する設定*/
            "menu_category": {
                "category": "items"
            }
        },
        "components": {
            /*1スタックが何個かの設定(デフォルトは64)*/
            "minecraft:max_stack_size": {
                "value": 1
            },
            /*アクションバーに表示されるアイテム名の設定(langファイルでも設定可)*/
            "minecraft:display_name": {
                "value": "§c時間減速"
            },
            /*アイテムのアイコン設定(RPのitem_texture.jsonでの設定要)*/
            "minecraft:icon": {
                "textures": {
                    "default": "timeeater_passive_health"
                }
            },
            /*アイテムのクールダウン設定*/
            "minecraft:cooldown": {
                /*クールダウンの識別名(なくても動くけどScript APIで使うから設定要)*/
                "category": "pvp:timeeater_passive_health",
                /*クールダウン時間(秒換算)*/
                "duration": 15
            }
        }
    }
}