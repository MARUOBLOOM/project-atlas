                "value": "§8木の葉の剣"
            },
            "minecraft:durability": {
                "damage_chance": {
                    "min": 100,
                    "max": 100
                },
                "max_durability": 1
            },
            "minecraft:damage": {
                "value": 19
            },
            "minecraft:weapon":{
                "category":"pvp:ninja_sword",
                "on_hit_entity":{
                    "event":ninja
                }
            },
            /*アイテムのアイコン設定(RPのitem_texture.jsonでの設定要)*/
            "minecraft:icon": {
                "textures": {
                    "default": "Ninja_sword"
                }
            }
        }
    }
}