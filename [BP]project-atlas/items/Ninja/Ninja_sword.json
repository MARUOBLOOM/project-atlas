{
    "format_version": "1.20.60",
    "minecraft:item": {
        "description": {
            "identifier": "pvp:ninja_sword",
            /*クリエイティブのアイテム欄に表示する設定*/
            "menu_category": {
                "category": "items"
            }
        },
        "components": {
            /*1スタックが何個かの設定(デフォルトは64)*/
